const axios = require("axios");
const cheerio = require("cheerio");
const cron = require("node-cron");
const Post = require("./models/Post");

async function scrape() {
  try {
    console.log("Scraping...");

    const { data } = await axios.get("https://www.freejobalert.com/");
    const $ = cheerio.load(data);

    $("a").each(async (i, el) => {
      const title = $(el).text().trim();
      const link = $(el).attr("href");

      if (
        title.includes("Recruitment") ||
        title.includes("Result") ||
        title.includes("Admit Card")
      ) {
        const exists = await Post.findOne({ title });

        if (!exists && title.length > 10) {
          await Post.create({
            title,
            link,
            category: "jobs"
          });

          console.log("Saved:", title);
        }
      }
    });

  } catch (err) {
    console.log("Error:", err.message);
  }
}

// Run every hour
cron.schedule("0 * * * *", scrape);

// Run on start
scrape();
